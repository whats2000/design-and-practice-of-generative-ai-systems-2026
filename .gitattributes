# Default: normalize line endings to LF on commit
* text=auto eol=lf

# Python source files
*.py text eol=lf

# Jupyter Notebooks — treat as text, use nbstripout or similar for diffs
*.ipynb text eol=lf

# TOML / config files
*.toml text eol=lf
*.lock text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts — keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files — do not modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.whl binary
*.bin binary
*.pt binary
*.pth binary
