    "安裝 Ollama: <br>\n",
    "\n",
    "```bash\n",
    "cat /etc/os-release\n",
    "sudo apt-get install zstd\n",
    "curl -fsSL https://ollama.com/install.sh | sh\n",
    "ollama serve &\n",
    "ollama pull phi3\n",
    "ollama list\n",
    "```"
   ]
  },
