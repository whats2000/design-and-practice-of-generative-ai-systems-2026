# Copy this file to .env and fill in your actual values.
# .env is gitignored and will NOT be committed.

# Groq API Key — get yours at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ngrok — get yours at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_TOKEN=your_ngrok_token_here

# LINE Bot — from LINE Developers Console
LINE_ACCESS_TOKEN=your_line_access_token_here
LINE_SECRET=your_line_secret_here
